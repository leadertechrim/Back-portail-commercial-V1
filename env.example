# Configuration pour l'environnement de production
# Copiez ce fichier vers .env et remplissez les valeurs

# ============================================================
# OBLIGATOIRES
# ============================================================

# Clé secrète pour JWT (générez une clé forte)
JWT_SECRET=585a49bed3854d26e4d34f076aab5c3aad03ee94f6e390ef9b2150d7d3eee688

# URI de connexion MongoDB Atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# ============================================================
# OPTIONNELLES (avec valeurs par défaut)
# ============================================================

# Port du serveur (Railway définit automatiquement PORT, ne pas modifier)
# PORT=8080

# Mode debug (false en production)
FLASK_DEBUG=false

# OpenRouter API pour classification IA
USE_OPENROUTER=true
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
OPENROUTER_MODEL=anthropic/claude-3-haiku

# Configuration du Scraper
SCRAPER_INTERVAL_MINUTES=30
SCRAPER_MAX_ERRORS=5

# Clé de chiffrement pour les données sensibles
ENCRYPTION_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
